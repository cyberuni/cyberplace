---
import { type CrewPlugin, readCrewPlugins } from 'cyberplace/tavern'

const crews = readCrewPlugins()

function countChips(crew: CrewPlugin): string[] {
	const chips: string[] = []
	if (crew.skillCount > 0) chips.push(`${crew.skillCount} skill${crew.skillCount === 1 ? '' : 's'}`)
	if (crew.agentCount > 0) chips.push(`${crew.agentCount} agent${crew.agentCount === 1 ? '' : 's'}`)
	if (crew.commandCount > 0) chips.push(`${crew.commandCount} command${crew.commandCount === 1 ? '' : 's'}`)
	return chips
}
---

{
	crews.length === 0 ? (
		<p class="tavern-empty">No crews are cataloged yet.</p>
	) : (
		<div class="tavern-storefront">
			{crews.map((crew) => (
				<article class="crew-card">
					<header class="crew-card-header">
						<h3 class="crew-name">{crew.name}</h3>
						<span class="crew-badge">crew</span>
						{countChips(crew).length > 0 && (
							<span class="crew-counts">{countChips(crew).join(' · ')}</span>
						)}
					</header>
					<p class="crew-description">{crew.description}</p>
					{crew.tags.length > 0 && (
						<div class="crew-tags">
							{crew.tags.map((tag) => (
								<span class="crew-tag">{tag}</span>
							))}
						</div>
					)}
					<footer class="crew-card-footer">
						<code class="crew-recruit">cyberplace add {crew.name}</code>
						<a class="crew-source-link" href={crew.sourceUrl} target="_blank" rel="noopener noreferrer">
							Source ↗
						</a>
					</footer>
				</article>
			))}
		</div>
	)
}

<style>
	.tavern-empty {
		color: var(--sl-color-gray-3);
		font-style: italic;
	}
	.tavern-storefront {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		margin: 1.5rem 0;
	}
	.crew-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 42rem;
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--linear-border);
		border-radius: 16px;
		background: var(--linear-panel-bg);
		box-shadow: var(--linear-shadow-card);
		transition: border-color 0.15s ease;
	}
	.crew-card:hover {
		border-color: var(--sl-color-accent);
	}
	.crew-card-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
	}
	.crew-name {
		margin: 0;
		font-size: var(--sl-text-lg);
		color: var(--sl-color-text);
	}
	.crew-badge {
		font-size: var(--sl-text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: var(--linear-accent-hover);
		background: var(--linear-accent-low);
		border: 1px solid var(--linear-accent-hover);
		border-radius: 999px;
		padding: 0.15rem 0.6rem;
	}
	.crew-counts {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		margin-left: auto;
	}
	.crew-description {
		margin: 0;
		color: var(--sl-color-gray-3);
		line-height: 1.5;
	}
	.crew-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.crew-tag {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		border: 1px solid var(--linear-border);
		border-radius: 999px;
		padding: 0.1rem 0.55rem;
	}
	.crew-card-footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-top: 0.25rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--linear-border);
	}
	.crew-recruit {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-text);
		background: var(--linear-panel-bg-elevated);
		border-radius: 6px;
		padding: 0.2rem 0.5rem;
	}
	.crew-source-link {
		font-size: var(--sl-text-sm);
		color: var(--linear-accent-link);
		text-decoration: none;
	}
	.crew-source-link:hover {
		text-decoration: underline;
	}
</style>

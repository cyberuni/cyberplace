{
	"name": "cyber-skills-root",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"check": "biome check --write",
		"cs": "changeset",
		"knip": "knip",
		"prepare": "node -e \"if(!(process.env.CI||process.env.GITHUB_ACTIONS))require('child_process').execSync('husky',{stdio:'inherit'})\"",
		"release": "changeset publish",
		"render:awesome-list": "pnpm --filter=cyber-skills render:awesome-list",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"verify": "turbo verify",
		"verify:specs": "node --experimental-strip-types --test plugins/sdd/skills/validate-spec/scripts/check-spec-state.test.mts plugins/sdd/skills/validate-spec/scripts/check-feature.test.mts plugins/sdd/agents/sdd-operator.test.mts && node plugins/sdd/skills/validate-spec/scripts/check-spec-state.mts && node plugins/sdd/skills/validate-spec/scripts/check-feature.mts",
		"verify:specs-new": "node --experimental-strip-types --test plugins/sdd-new/skills/validate-spec/scripts/check-spec-state.test.mts && node plugins/sdd-new/skills/validate-spec/scripts/check-spec-state.mts --root .agents/specs",
		"version": "changeset version",
		"web": "pnpm run --filter=website"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.29.4",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@repobuddy/biome": "^2.3.1",
		"@types/node": "^24.12.4",
		"husky": "^9.1.7",
		"knip": "^6.14.1",
		"turbo": "^2.9.14",
		"typescript": "^6.0.0"
	},
	"packageManager": "pnpm@11.0.0",
	"engines": {
		"node": ">=22"
	}
}

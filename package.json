{
	"name": "cyber-skills",
	"version": "0.0.1",
	"description": "Opinionated skills, hooks, and workflows for AI agents",
	"keywords": [
		"agent-skill",
		"claude-code",
		"cursor",
		"codex"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cyberuni/cyber-skills.git"
	},
	"author": "unional <homawong@gmail.com>",
	"license": "MIT",
	"type": "module",
	"bin": {
		"cyber-skills": "./bin/cyber-skills.mjs"
	},
	"files": [
		"bin",
		"hooks",
		"skills"
	],
	"scripts": {
		"build": "tsdown",
		"prepare": "husky",
		"prepack": "pnpm build",
		"check": "biome check --write .",
		"cs": "changeset",
		"format": "biome format --write .",
		"knip": "knip",
		"lint": "biome check .",
		"release": "changeset publish",
		"render:awesome-list": "pnpm build && node skills/update-awesome-list/scripts/render-awesome-list.mjs",
		"test": "pnpm build && vitest run src",
		"test:audit": "pnpm build && node skills/audit-skill/scripts/validate-skills.mjs",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:audit",
		"version": "changeset version"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.29.4",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@repobuddy/biome": "^2.3.1",
		"@types/node": "^24.10.1",
		"husky": "^9.1.7",
		"knip": "^6.14.1",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.0",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@11.0.0",
	"engines": {
		"node": ">=22"
	}
}

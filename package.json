{
	"name": "cyber-skills-root",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"check": "biome check --write .",
		"cs": "changeset",
		"format": "biome format --write .",
		"lint": "biome check .",
		"prepare": "node -e \"if(!(process.env.CI||process.env.GITHUB_ACTIONS))require('child_process').execSync('husky',{stdio:'inherit'})\"",
		"release": "changeset publish",
		"render:awesome-list": "pnpm --filter=cyber-skills render:awesome-list",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"verify": "turbo verify",
		"version": "changeset version",
		"web": "pnpm run --filter=web"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.29.4",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@repobuddy/biome": "^2.3.1",
		"husky": "^9.1.7",
		"turbo": "^2.9.14"
	},
	"packageManager": "pnpm@11.0.0",
	"engines": {
		"node": ">=22"
	}
}

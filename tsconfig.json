{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true
	},
	"include": ["bin/**/*.mts", "hooks/**/*.mts", "skills/**/*.mts", "tests/**/*.mts"]
}

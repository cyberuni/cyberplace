{
  "permissions": {
    "allow": [
      "Bash(pnpm vitest *)",
      "Bash(git commit -m ' *)",
      "WebFetch(domain:github.com)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cyber-skills/bin/cyber-skills.mjs hook run --name commit-discipline --extract AGENTS.md --heading 'Commit Discipline'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "aces@cyber-skills-next": true,
    "quill@cyber-skills-next": true,
    "sdd@cyber-skills-next": true
  }
}

{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node bin/cyber-skills.mjs run-hook mark-internal"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/cyber-skills.mjs run-hook inject-local-augmentations"
          },
          {
            "type": "command",
            "command": "node bin/cyber-skills.mjs run-hook commit-discipline"
          }
        ]
      }
    ]
  }
}

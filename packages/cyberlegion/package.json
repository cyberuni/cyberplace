{
	"name": "cyberlegion",
	"version": "0.1.0",
	"description": "Harness-agnostic agent session spawning, messaging, and dispatch over the filesystem",
	"keywords": [
		"agent",
		"claude-code",
		"cursor",
		"codex",
		"inter-agent",
		"dispatch",
		"tmux"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cyberuni/cyberplace.git",
		"directory": "packages/cyberlegion"
	},
	"license": "MIT",
	"author": "unional <homawong@gmail.com>",
	"type": "module",
	"bin": {
		"cyberlegion": "bin/cyberlegion.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"bin",
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsx src/cli.ts",
		"prepack": "pnpm build",
		"test": "pnpm build && vitest run src",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"tsdown": "^0.22.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.0",
		"vitest": "^4.1.7"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}

{
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[typescript]": {
		"editor.codeActionsOnSave": {
			"source.organizeImports.biome": "explicit"
		},
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"cSpell.words": [
		"acked",
		"acks",
		"Agentic",
		"anthropics",
		"criticals",
		"cyberfleet",
		"cyberlegion",
		"cyberplace",
		"evals",
		"exfiltration",
		"fdisk",
		"Governances",
		"herdr",
		"hookify",
		"repobuddy",
		"SCIM",
		"skillify",
		"subdirs",
		"toon",
		"trailofbits"
	],
	"cucumber.features": ["artifacts/specs/**/*.feature"],
	"cucumber.glue": ["**/.vscode/cucumber-glue.js"],
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit"
	}
}

		"editor.formatOnSave": true
	},
	"cSpell.words": [
		"Agentic",
		"anthropics",
		"criticals",
		"exfiltration",
		"fdisk",
		"Governances",
		"repobuddy",
		"skillify",
		"subdirs",
		"trailofbits"
	],
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit"
	}
}
